# Mainlayer credentials
# Get your API key at https://app.mainlayer.xyz
MAINLAYER_API_KEY=ml_your_api_key_here

# Resource ID — generated by `npm run setup` (run once)
RESOURCE_ID=res_your_resource_id_here

# Optional: used by setup.ts
RESOURCE_NAME=My API
RESOURCE_DESCRIPTION=Access to My API endpoints
RESOURCE_PRICE_USD=0.01
RESOURCE_PRICING_MODEL=per_call

# Server settings
PORT=3000
